<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ━━━━━━━━━━━━━━━ 필수 권한 ━━━━━━━━━━━━━━━ -->

    <!-- 인터넷: URL 정보 파싱 및 영상 스트림 다운로드 -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Android 9(API 28) 이하: 외부 저장소 쓰기 권한 -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!--
        Android 13(API 33) 이상: 미디어 타입별 세분화된 권한.
        WRITE_EXTERNAL_STORAGE 대신 이 권한을 사용해야 함.
    -->
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <!--
        Android 14(API 34) 이상: 부분 미디어 접근 권한.
        사용자가 일부 파일만 선택적으로 허용할 수 있게 함.
    -->
    <uses-permission android:name="android.permission.READ_MEDIA_VISUAL_USER_SELECTED" />

    <!-- 알림 권한: 다운로드 진행 상태 알림 (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- ━━━━━━━━━━━━━━━ 앱 설정 ━━━━━━━━━━━━━━━ -->
    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.VideoDownloader"
        android:requestLegacyExternalStorage="false"
        android:usesCleartextTraffic="true">

        <!--
            usesCleartextTraffic="true":
            일부 미디어 CDN이 HTTP를 사용하는 경우가 있어 설정.
            보안상 필요 없으면 제거 가능.
        -->

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.VideoDownloader">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- 외부 공유 인텐트로 URL을 받을 수 있는 인텐트 필터 -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>

    </application>

</manifest>
